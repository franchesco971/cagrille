{% set _pagination = aliexpress_orders_paginated(app.request.query.getInt('page', 1)) %}
{% set orders   = _pagination.orders %}
{% set page     = _pagination.page %}
{% set lastPage = _pagination.lastPage %}
{% set total    = _pagination.total %}
{% set stats    = aliexpress_order_stats() %}
<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl">
            <div class="row g-2 align-items-center">
                <div class="col">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item">
                                <a href="{{ path('sylius_admin_dashboard') }}">Administration</a>
                            </li>
                            <li class="breadcrumb-item active" aria-current="page">Commandes AliExpress</li>
                        </ol>
                    </nav>
                    <h2 class="page-title">Commandes AliExpress</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="page-body">
        <div class="container-xl">

            {# Flash messages #}
            {% include '@SyliusAdmin/shared/crud/common/content/flashes.html.twig' %}

            {# ── Stats ─────────────────────────────────────────────────────── #}
            <div class="row row-deck row-cards mb-4">
                <div class="col-sm-6 col-lg-2">
                    <div class="card">
                        <div class="card-body p-3 text-center">
                            <div class="text-muted small">Total</div>
                            <div class="h2 mb-0">{{ stats.total }}</div>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-2">
                    <div class="card">
                        <div class="card-body p-3 text-center">
                            <div class="text-muted small">En attente</div>
                            <div class="h2 mb-0 text-secondary">{{ stats.pending }}</div>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-2">
                    <div class="card">
                        <div class="card-body p-3 text-center">
                            <div class="text-muted small">Passées</div>
                            <div class="h2 mb-0 text-info">{{ stats.placed }}</div>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-2">
                    <div class="card">
                        <div class="card-body p-3 text-center">
                            <div class="text-muted small">Échouées</div>
                            <div class="h2 mb-0 text-danger">{{ stats.failed }}</div>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-2">
                    <div class="card">
                        <div class="card-body p-3 text-center">
                            <div class="text-muted small">Expédiées</div>
                            <div class="h2 mb-0 text-warning">{{ stats.shipped }}</div>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-2">
                    <div class="card">
                        <div class="card-body p-3 text-center">
                            <div class="text-muted small">Livrées</div>
                            <div class="h2 mb-0 text-success">{{ stats.delivered }}</div>
                        </div>
                    </div>
                </div>
            </div>

            {# ── Tableau ───────────────────────────────────────────────────── #}
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Liste des commandes</h3>
                </div>
                <div class="table-responsive">
                    <table class="table table-vcenter card-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Commande Sylius</th>
                                <th>ID AliExpress</th>
                                <th>Produit AliExpress</th>
                                <th>Qté</th>
                                <th>Montant</th>
                                <th>Statut</th>
                                <th>Suivi</th>
                                <th>Créée le</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for order in orders %}
                                <tr>
                                    <td>{{ order.id }}</td>
                                    <td>
                                        <a href="{{ path('sylius_admin_order_show', {id: order.syliusOrderId}) }}" target="_blank">
                                            #{{ order.syliusOrderId }}
                                        </a>
                                    </td>
                                    <td>
                                        {% if order.aliExpressOrderId %}
                                            <code>{{ order.aliExpressOrderId }}</code>
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>
                                    <td><code>{{ order.aliExpressProductId }}</code></td>
                                    <td>{{ order.quantity }}</td>
                                    <td>
                                        {% if order.totalAmount > 0 %}
                                            {{ order.totalAmount|number_format(2) }} {{ order.currency }}
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <span class="badge {{ order.status.badgeClass }} text-white">
                                            {{ order.status.label }}
                                        </span>
                                    </td>
                                    <td>
                                        {% if order.trackingNumber %}
                                            <small><code>{{ order.trackingNumber }}</code></small>
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <small>{{ order.createdAt|date('d/m/Y H:i') }}</small>
                                    </td>
                                    <td>
                                        <a href="{{ path('cagrille_admin_aliexpress_order_show', {id: order.id}) }}"
                                           class="btn btn-sm btn-outline-secondary">
                                            Détail
                                        </a>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="10" class="text-center text-muted py-4">
                                        Aucune commande AliExpress.
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                {# ── Pagination ──────────────────────────────────────────────── #}
                {% if lastPage > 1 %}
                    <div class="card-footer d-flex align-items-center">
                        <p class="m-0 text-muted">
                            Page <strong>{{ page }}</strong> / <strong>{{ lastPage }}</strong>
                            — {{ total }} résultat(s)
                        </p>
                        <ul class="pagination m-0 ms-auto">
                            {% if page > 1 %}
                                <li class="page-item">
                                    <a class="page-link" href="{{ path('cagrille_admin_aliexpress_order_index', {page: page - 1}) }}">
                                        Précédent
                                    </a>
                                </li>
                            {% endif %}
                            {% if page < lastPage %}
                                <li class="page-item">
                                    <a class="page-link" href="{{ path('cagrille_admin_aliexpress_order_index', {page: page + 1}) }}">
                                        Suivant
                                    </a>
                                </li>
                            {% endif %}
                        </ul>
                    </div>
                {% endif %}
            </div>

        </div>
    </div>
</div>
