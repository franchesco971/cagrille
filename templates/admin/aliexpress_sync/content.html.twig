{% set token = aliexpress_token_info() %}
<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl">
            <div class="row g-2 align-items-center">
                <div class="col">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item">
                                <a href="{{ path('sylius_admin_dashboard') }}">Administration</a>
                            </li>
                            <li class="breadcrumb-item active" aria-current="page">Synchronisation AliExpress</li>
                        </ol>
                    </nav>
                    <h2 class="page-title">
                        Synchronisation AliExpress
                    </h2>
                </div>
            </div>
        </div>
    </div>

    <div class="page-body">
        <div class="container-xl">

            {# Flash messages #}
            {% include '@SyliusAdmin/shared/crud/common/content/flashes.html.twig' %}

            {# ── Statut du token OAuth ─────────────────────────────────────── #}
            <div class="row mt-3">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Token OAuth AliExpress</h3>
                            <div class="card-options">
                                {% if token.expires_at is not null %}
                                    {% if token.expiring_soon %}
                                        <span class="badge bg-warning text-white">Expire bientôt</span>
                                    {% else %}
                                        <span class="badge bg-success text-white">Valide</span>
                                    {% endif %}
                                {% else %}
                                    <span class="badge bg-secondary text-white">Statut inconnu (token env)</span>
                                {% endif %}
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="row g-3 align-items-center">
                                <div class="col-12 col-md-auto">
                                    {% if token.expires_at is not null %}
                                        <p class="mb-0">
                                            Expiration :
                                            <strong>{{ token.expires_at|date('d/m/Y à H:i') }}</strong>
                                        </p>
                                    {% else %}
                                        <p class="mb-0 text-muted">
                                            Aucune date d'expiration connue — token issu de la variable d'environnement.
                                            Connectez-vous via OAuth pour activer le renouvellement automatique.
                                        </p>
                                    {% endif %}
                                </div>
                                <div class="col-12 col-md-auto ms-md-auto d-flex gap-2 flex-wrap">

                                    {# Bouton : rafraîchir via refresh_token #}
                                    {% if token.has_refresh_token %}
                                        <form method="post" action="{{ path('cagrille_admin_aliexpress_sync_auth_refresh') }}" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('aliexpress_auth_refresh') }}">
                                            <button type="submit" class="btn btn-sm btn-outline-primary">
                                                Rafraîchir le token
                                            </button>
                                        </form>
                                    {% endif %}

                                    {# Bouton : lancer le flux OAuth complet #}
                                    <a href="{{ path('cagrille_admin_aliexpress_sync_auth_start') }}" class="btn btn-sm btn-primary">
                                        Connecter via OAuth
                                    </a>
                                </div>
                            </div>

                            {# URL de callback à enregistrer dans le portail développeur #}
                            <div class="mt-3 p-3 bg-light rounded border">
                                <small class="text-muted d-block mb-1">
                                    <strong>URL de callback à enregistrer</strong> dans votre app AliExpress
                                    (<a href="https://developers.aliexpress-solution.com" target="_blank" rel="noopener noreferrer">portail développeur</a>) :
                                </small>
                                <code class="user-select-all">{{ token.callback_url }}</code>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row row-cards mt-3">

                {# ── Import d'un produit individuel ──────────────────────── #}
                <div class="col-12 col-md-6 col-xl-4">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Importer un produit</h3>
                        </div>
                        <div class="card-body">
                            <p class="text-muted">
                                Saisir l'identifiant AliExpress (<code>item_id</code>) d'un produit
                                pour l'importer ou le mettre à jour dans le catalogue Sylius.
                            </p>
                            <form method="post" action="{{ path('cagrille_admin_aliexpress_sync_import_one') }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('aliexpress_import_one') }}">
                                <div class="mb-3">
                                    <label for="item_id" class="form-label">Item ID AliExpress</label>
                                    <input
                                        type="text"
                                        id="item_id"
                                        name="item_id"
                                        class="form-control"
                                        placeholder="ex : 1234567890"
                                        required
                                        pattern="[0-9]+"
                                        title="Saisir uniquement des chiffres"
                                    >
                                    <div class="form-hint">Identifiant numérique du produit sur AliExpress.</div>
                                </div>
                                <button type="submit" class="btn btn-primary w-100">
                                    Importer ce produit
                                </button>
                            </form>
                        </div>
                    </div>
                </div>

                {# ── Synchronisation par mot-clé ─────────────────────────── #}
                <div class="col-12 col-md-6 col-xl-4">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Sync par mot-clé</h3>
                        </div>
                        <div class="card-body">
                            <p class="text-muted">
                                Rechercher et synchroniser tous les produits correspondant
                                à un mot-clé sur AliExpress.
                            </p>
                            <form method="post" action="{{ path('cagrille_admin_aliexpress_sync_sync_keyword') }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('aliexpress_sync_keyword') }}">
                                <div class="mb-3">
                                    <label for="keyword" class="form-label">Mot-clé</label>
                                    <input
                                        type="text"
                                        id="keyword"
                                        name="keyword"
                                        class="form-control"
                                        placeholder="ex : barbecue"
                                        required
                                    >
                                    <div class="form-hint">Le terme sera recherché sur l'API AliExpress.</div>
                                </div>
                                <button type="submit" class="btn btn-warning w-100">
                                    Synchroniser ce mot-clé
                                </button>
                            </form>
                        </div>
                    </div>
                </div>

                {# ── Synchronisation complète ────────────────────────────── #}
                <div class="col-12 col-md-6 col-xl-4">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Synchronisation complète</h3>
                        </div>
                        <div class="card-body">
                            <p class="text-muted">
                                Lance la synchronisation sur <strong>tous les mots-clés</strong>
                                configurés dans <code>ALIEXPRESS_SYNC_KEYWORDS</code>.
                                Cette opération peut prendre plusieurs minutes.
                            </p>
                            <form method="post" action="{{ path('cagrille_admin_aliexpress_sync_sync_all') }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('aliexpress_sync_all') }}">
                                <button
                                    type="submit"
                                    class="btn btn-danger w-100"
                                    onclick="return confirm('Lancer la synchronisation complète ? Cela peut prendre plusieurs minutes.')"
                                >
                                    Lancer la sync complète
                                </button>
                            </form>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>
