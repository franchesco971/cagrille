#!/usr/bin/env bash
# =============================================================================
# bin/init-cagrille
#
# Initialise le site Cagrille de zéro en conservant les données de référence :
#   - Taxons Barbecues, Accessoires et leurs enfants
#   - Channel CG_EURO_STORE
#   - Countries, Zones, Currencies, Locales
#
# Usage :
#   APP_ENV=prod bash bin/init-cagrille
#   APP_ENV=prod ADMIN_EMAIL=you@example.com bash bin/init-cagrille
#
# Pré-requis : PHP 8.x en CLI, accès SSH, projet Symfony déployé
# =============================================================================

set -euo pipefail

# ──────────────────────────────────────────────────────────────────────────────
# Configuration
# ──────────────────────────────────────────────────────────────────────────────
APP_ENV="${APP_ENV:-prod}"
PHP="${PHP:-php}"
CONSOLE="$PHP bin/console --env=$APP_ENV --no-debug"

# ──────────────────────────────────────────────────────────────────────────────
# Helpers
# ──────────────────────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; BOLD='\033[1m'; NC='\033[0m'

step()    { echo -e "\n${BOLD}${BLUE}▶ $*${NC}"; }
success() { echo -e "  ${GREEN}✔ $*${NC}"; }
warn()    { echo -e "  ${YELLOW}⚠ $*${NC}"; }
error()   { echo -e "  ${RED}✘ $*${NC}" >&2; exit 1; }

# ──────────────────────────────────────────────────────────────────────────────
# Vérifications préliminaires
# ──────────────────────────────────────────────────────────────────────────────
[[ -f "bin/console" ]] || error "Lancez ce script depuis la racine du projet (bin/console introuvable)."
[[ -x "$($PHP -r 'echo 1;' 2>/dev/null && echo ok)" ]] || true
$PHP -r 'exit(0);' 2>/dev/null || error "PHP CLI introuvable ou non fonctionnel."

# ──────────────────────────────────────────────────────────────────────────────
# Bannière
# ──────────────────────────────────────────────────────────────────────────────
echo ""
echo -e "${BOLD}╔═══════════════════════════════════════════════════════════╗${NC}"
echo -e "${BOLD}║         Cagrille — Initialisation from scratch            ║${NC}"
echo -e "${BOLD}╚═══════════════════════════════════════════════════════════╝${NC}"
echo -e "  Environnement : ${YELLOW}$APP_ENV${NC}"
echo ""
warn "ATTENTION : Cette opération va SUPPRIMER et RECRÉER la base de données."
echo -n "  Confirmer ? [oui/NON] : "
read -r CONFIRM
[[ "$CONFIRM" == "oui" ]] || error "Opération annulée."

# ──────────────────────────────────────────────────────────────────────────────
# Étape 1 : Cache Symfony
# ──────────────────────────────────────────────────────────────────────────────
step "Nettoyage du cache Symfony"
$CONSOLE cache:clear --no-warmup
success "Cache vidé."

# ──────────────────────────────────────────────────────────────────────────────
# Étape 2 : Reset base de données
# ──────────────────────────────────────────────────────────────────────────────
step "Suppression de la base de données"
$CONSOLE doctrine:database:drop --force --if-exists
success "Base supprimée."

step "Création de la base de données"
$CONSOLE doctrine:database:create
success "Base créée."

step "Exécution des migrations Doctrine"
$CONSOLE doctrine:migrations:migrate --no-interaction
success "Migrations terminées."

# ──────────────────────────────────────────────────────────────────────────────
# Étape 3 : Insertion des données de référence via PHP/PDO
# ──────────────────────────────────────────────────────────────────────────────
step "Insertion des données de référence"

$PHP bin/seed-reference-data.php

success "Données de référence traitées (voir tableau ci-dessus)."

# ──────────────────────────────────────────────────────────────────────────────
# Étape 4 : Création du compte administrateur (via SQL + bcrypt PHP)
# ──────────────────────────────────────────────────────────────────────────────
step "Création du compte administrateur Sylius"
echo ""
echo "  Entrez les informations du compte admin :"
echo -n "  E-mail          [admin@cagrille.fr] : "
read -r ADMIN_EMAIL
ADMIN_EMAIL="${ADMIN_EMAIL:-admin@cagrille.fr}"

echo -n "  Nom d'utilisateur          [admin] : "
read -r ADMIN_USERNAME
ADMIN_USERNAME="${ADMIN_USERNAME:-admin}"

echo -n "  Prénom                   [Admin]   : "
read -r ADMIN_FIRST
ADMIN_FIRST="${ADMIN_FIRST:-Admin}"

echo -n "  Nom de famille        [Cagrille]   : "
read -r ADMIN_LAST
ADMIN_LAST="${ADMIN_LAST:-Cagrille}"

echo -n "  Mot de passe (caché)               : "
read -rs ADMIN_PASSWORD
echo ""
[[ -n "$ADMIN_PASSWORD" ]] || error "Le mot de passe ne peut pas être vide."

$PHP bin/create-admin.php "$ADMIN_EMAIL" "$ADMIN_USERNAME" "$ADMIN_FIRST" "$ADMIN_LAST" "$ADMIN_PASSWORD"

success "Administrateur : $ADMIN_EMAIL / $ADMIN_USERNAME"

# ──────────────────────────────────────────────────────────────────────────────
# Étape 5 : Assets & cache warmup (facultatif en prod)
# ──────────────────────────────────────────────────────────────────────────────
step "Warmup du cache Symfony"
$CONSOLE cache:warmup
success "Cache préchauffé."

# ──────────────────────────────────────────────────────────────────────────────
# Résumé final
# ──────────────────────────────────────────────────────────────────────────────
echo ""
echo -e "${BOLD}${GREEN}═══════════════════════════════════════════════════════════${NC}"
echo -e "${BOLD}${GREEN}  ✔  Initialisation terminée avec succès !${NC}"
echo -e "${BOLD}${GREEN}═══════════════════════════════════════════════════════════${NC}"
echo ""
echo -e "  Admin URL   : https://<votre-domaine>/admin"
echo -e "  Identifiant : ${YELLOW}$ADMIN_EMAIL${NC}"
echo ""
echo -e "  ${BLUE}Données conservées :${NC}"
echo -e "    • Taxons    : MENU_CATEGORY › Barbecues (4 enfants) + Accessoires (4 enfants)"
echo -e "    • Channel   : CG_EURO_STORE (fr_FR / EUR / zone EEA / pays FR)"
echo -e "    • Countries : AT AU BE CA CH CN DE DK ES FR GB IT MX NL NO NZ PL PT SE US"
echo -e "    • Zones     : US (priority 2) · WORLD (priority 1) · EEA (priority 0)"
echo -e "    • Currencies: EUR USD PLN CAD CNY NZD GBP AUD MXN"
echo -e "    • Locales   : en_US de_DE fr_FR pl_PL es_ES es_MX pt_PT zh_CN"
echo -e "    • Tax cat.  : all (Tous produits)"
echo -e "    • Tax rate  : tax20 (20%, zone EEA)"
echo -e "    • Ship. cat : default"
echo -e "    • Shipping  : default (gratuit, zone EEA, lié CG_EURO_STORE)"
echo ""
