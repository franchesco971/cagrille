#!/usr/bin/env bash
# =============================================================================
# bin/init-cagrille
#
# Initialise le site Cagrille de zéro en conservant les données de référence :
#   - Taxons Barbecues, Accessoires et leurs enfants
#   - Channel CG_EURO_STORE
#   - Countries, Zones, Currencies, Locales
#
# Usage :
#   APP_ENV=prod bash bin/init-cagrille
#   APP_ENV=prod ADMIN_EMAIL=you@example.com bash bin/init-cagrille
#
# Pré-requis : PHP 8.x en CLI, accès SSH, projet Symfony déployé
# =============================================================================

set -euo pipefail

# ──────────────────────────────────────────────────────────────────────────────
# Configuration
# ──────────────────────────────────────────────────────────────────────────────
APP_ENV="${APP_ENV:-prod}"
PHP="${PHP:-php}"
CONSOLE="$PHP bin/console --env=$APP_ENV --no-debug"

# ──────────────────────────────────────────────────────────────────────────────
# Helpers
# ──────────────────────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; BOLD='\033[1m'; NC='\033[0m'

step()    { echo -e "\n${BOLD}${BLUE}▶ $*${NC}"; }
success() { echo -e "  ${GREEN}✔ $*${NC}"; }
warn()    { echo -e "  ${YELLOW}⚠ $*${NC}"; }
error()   { echo -e "  ${RED}✘ $*${NC}" >&2; exit 1; }

# ──────────────────────────────────────────────────────────────────────────────
# Vérifications préliminaires
# ──────────────────────────────────────────────────────────────────────────────
[[ -f "bin/console" ]] || error "Lancez ce script depuis la racine du projet (bin/console introuvable)."
[[ -x "$($PHP -r 'echo 1;' 2>/dev/null && echo ok)" ]] || true
$PHP -r 'exit(0);' 2>/dev/null || error "PHP CLI introuvable ou non fonctionnel."

# ──────────────────────────────────────────────────────────────────────────────
# Bannière
# ──────────────────────────────────────────────────────────────────────────────
echo ""
echo -e "${BOLD}╔═══════════════════════════════════════════════════════════╗${NC}"
echo -e "${BOLD}║         Cagrille — Initialisation from scratch            ║${NC}"
echo -e "${BOLD}╚═══════════════════════════════════════════════════════════╝${NC}"
echo -e "  Environnement : ${YELLOW}$APP_ENV${NC}"
echo ""
warn "ATTENTION : Cette opération va SUPPRIMER et RECRÉER la base de données."
echo -n "  Confirmer ? [oui/NON] : "
read -r CONFIRM
[[ "$CONFIRM" == "oui" ]] || error "Opération annulée."

# ──────────────────────────────────────────────────────────────────────────────
# Étape 1 : Cache Symfony
# ──────────────────────────────────────────────────────────────────────────────
step "Nettoyage du cache Symfony"
$CONSOLE cache:clear --no-warmup
success "Cache vidé."

# ──────────────────────────────────────────────────────────────────────────────
# Étape 2 : Reset base de données
# ──────────────────────────────────────────────────────────────────────────────
step "Suppression de la base de données"
$CONSOLE doctrine:database:drop --force --if-exists
success "Base supprimée."

step "Création de la base de données"
$CONSOLE doctrine:database:create
success "Base créée."

step "Exécution des migrations Doctrine"
$CONSOLE doctrine:migrations:migrate --no-interaction
success "Migrations terminées."

# ──────────────────────────────────────────────────────────────────────────────
# Étape 3 : Insertion des données de référence via PHP/PDO
# ──────────────────────────────────────────────────────────────────────────────
step "Insertion des données de référence"

$PHP << 'PHPEOF'
<?php
/**
 * Seed idempotent des données de référence Cagrille.
 * Chaque entité n'est insérée QUE SI elle n'existe pas encore.
 */

// ── Chargement du DATABASE_URL ──────────────────────────────────────────────
function loadDotEnv(string $file): void
{
    if (!is_file($file)) {
        return;
    }
    foreach (file($file, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES) as $line) {
        if (str_starts_with(trim($line), '#') || !str_contains($line, '=')) {
            continue;
        }
        [$key, $value] = explode('=', $line, 2);
        $key   = trim($key);
        $value = trim($value, " \t\n\r\0\x0B\"'");
        if (!isset($_ENV[$key])) {
            $_ENV[$key] = $value;
            putenv("$key=$value");
        }
    }
}

loadDotEnv('.env');
loadDotEnv('.env.local');

$rawUrl = $_ENV['DATABASE_URL'] ?? getenv('DATABASE_URL') ?? '';
if (empty($rawUrl)) {
    fwrite(STDERR, "[ERR] DATABASE_URL introuvable dans les fichiers .env.\n");
    exit(1);
}

$appEnv = $_ENV['APP_ENV'] ?? getenv('APP_ENV') ?: 'prod';
$rawUrl = str_replace('%kernel.environment%', $appEnv, $rawUrl);

$parsed = parse_url($rawUrl);
if ($parsed === false || !isset($parsed['host'], $parsed['path'])) {
    fwrite(STDERR, "[ERR] DATABASE_URL mal formée : $rawUrl\n");
    exit(1);
}

$dbHost = $parsed['host'];
$dbPort = $parsed['port'] ?? 3306;
$dbName = strtok(ltrim($parsed['path'], '/'), '?');
$dbUser = isset($parsed['user']) ? urldecode($parsed['user']) : 'root';
$dbPass = isset($parsed['pass']) ? urldecode($parsed['pass']) : '';

try {
    $pdo = new PDO(
        "mysql:host=$dbHost;port=$dbPort;dbname=$dbName;charset=utf8mb4",
        $dbUser,
        $dbPass,
        [
            PDO::ATTR_ERRMODE            => PDO::ERRMODE_EXCEPTION,
            PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC,
        ]
    );
} catch (PDOException $e) {
    fwrite(STDERR, "[ERR] Connexion PDO impossible : " . $e->getMessage() . "\n");
    exit(1);
}

// ── Helpers idempotents ───────────────────────────────────────────────────────

/**
 * Retourne l'id existant si $uniqueCol=$value, sinon insère et retourne le nouvel id.
 * $created est mis à true si une insertion a eu lieu.
 */
function find_or_create(
    PDO    $pdo,
    string $table,
    string $uniqueCol,
    string $value,
    string $insertSql,
    array  $insertParams,
    bool   &$created = false
): int {
    $stmt = $pdo->prepare("SELECT id FROM $table WHERE $uniqueCol = ? LIMIT 1");
    $stmt->execute([$value]);
    $row = $stmt->fetch();
    if ($row) {
        $created = false;
        return (int) $row['id'];
    }
    $pdo->prepare($insertSql)->execute($insertParams);
    $created = true;
    return (int) $pdo->lastInsertId();
}

/**
 * Récupère l'id en base, lève une exception si absent.
 */
function fetch_id(PDO $pdo, string $table, string $column, string $value): int
{
    $stmt = $pdo->prepare("SELECT id FROM $table WHERE $column = ? LIMIT 1");
    $stmt->execute([$value]);
    $row = $stmt->fetch();
    if (!$row) {
        throw new RuntimeException("Introuvable : $table.$column='$value'");
    }
    return (int) $row['id'];
}

/**
 * INSERT IGNORE sur une table pivot (clé composite).
 * Retourne true si inséré, false si existait déjà.
 */
function insert_pivot(PDO $pdo, string $table, string $col1, int $val1, string $col2, int $val2): bool
{
    $stmt = $pdo->prepare("INSERT IGNORE INTO $table ($col1, $col2) VALUES (?, ?)");
    $stmt->execute([$val1, $val2]);
    return $stmt->rowCount() > 0;
}

/**
 * Vérifie si un membre de zone (code + zone_id) existe déjà.
 */
function zone_member_exists(PDO $pdo, string $code, int $zoneId): bool
{
    $stmt = $pdo->prepare("SELECT 1 FROM sylius_zone_member WHERE code = ? AND belongs_to = ? LIMIT 1");
    $stmt->execute([$code, $zoneId]);
    return (bool) $stmt->fetch();
}

/**
 * Vérifie si une traduction de taxon (taxon_id + locale) existe déjà.
 */
function taxon_translation_exists(PDO $pdo, int $taxonId, string $locale): bool
{
    $stmt = $pdo->prepare(
        "SELECT 1 FROM sylius_taxon_translation WHERE translatable_id = ? AND locale = ? LIMIT 1"
    );
    $stmt->execute([$taxonId, $locale]);
    return (bool) $stmt->fetch();
}

// ── Compteurs ─────────────────────────────────────────────────────────────────
$stats = [
    'currencies' => ['inserted' => 0, 'skipped' => 0],
    'locales'    => ['inserted' => 0, 'skipped' => 0],
    'countries'  => ['inserted' => 0, 'skipped' => 0],
    'zones'      => ['inserted' => 0, 'skipped' => 0],
    'taxons'     => ['inserted' => 0, 'skipped' => 0],
    'channel'    => ['inserted' => 0, 'skipped' => 0],
];

$now = date('Y-m-d H:i:s');
$pdo->exec('SET FOREIGN_KEY_CHECKS = 0');

// ──── CURRENCIES ──────────────────────────────────────────────────────────────
echo "  → Currencies...\n";
$currencies = ['EUR', 'USD', 'PLN', 'CAD', 'CNY', 'NZD', 'GBP', 'AUD', 'MXN'];
foreach ($currencies as $code) {
    $stmt = $pdo->prepare("INSERT IGNORE INTO sylius_currency (code, created_at, updated_at) VALUES (?, ?, ?)");
    $stmt->execute([$code, $now, $now]);
    $stmt->rowCount() > 0 ? $stats['currencies']['inserted']++ : $stats['currencies']['skipped']++;
}

// ──── LOCALES ─────────────────────────────────────────────────────────────────
echo "  → Locales...\n";
$locales = ['en_US', 'de_DE', 'fr_FR', 'pl_PL', 'es_ES', 'es_MX', 'pt_PT', 'zh_CN'];
foreach ($locales as $code) {
    $stmt = $pdo->prepare("INSERT IGNORE INTO sylius_locale (code, created_at, updated_at) VALUES (?, ?, ?)");
    $stmt->execute([$code, $now, $now]);
    $stmt->rowCount() > 0 ? $stats['locales']['inserted']++ : $stats['locales']['skipped']++;
}

// ──── COUNTRIES ───────────────────────────────────────────────────────────────
echo "  → Countries...\n";
$countries = [
    'AT', 'AU', 'BE', 'CA', 'CH', 'CN', 'DE', 'DK', 'ES', 'FR',
    'GB', 'IT', 'MX', 'NL', 'NO', 'NZ', 'PL', 'PT', 'SE', 'US',
];
foreach ($countries as $code) {
    $stmt = $pdo->prepare("INSERT IGNORE INTO sylius_country (code, enabled) VALUES (?, 1)");
    $stmt->execute([$code]);
    $stmt->rowCount() > 0 ? $stats['countries']['inserted']++ : $stats['countries']['skipped']++;
}

// ──── ZONES ───────────────────────────────────────────────────────────────────
echo "  → Zones...\n";
$zones = [
    'US'    => ['name' => 'United States of America', 'type' => 'country', 'members' => ['US']],
    'WORLD' => ['name' => 'Rest of the World',        'type' => 'country', 'members' => ['AU','CA','CN','DE','ES','FR','GB','MX','NZ','PL','PT']],
    'EEA'   => ['name' => 'European Economic Area',   'type' => 'country', 'members' => ['AT','BE','CH','DE','DK','ES','FR','IT','NL','NO','PL','PT','SE']],
];
foreach ($zones as $code => $zone) {
    $created = false;
    $zoneId  = find_or_create(
        $pdo, 'sylius_zone', 'code', $code,
        "INSERT INTO sylius_zone (code, name, type) VALUES (?, ?, ?)",
        [$code, $zone['name'], $zone['type']],
        $created
    );
    $created ? $stats['zones']['inserted']++ : $stats['zones']['skipped']++;

    foreach ($zone['members'] as $memberCode) {
        if (!zone_member_exists($pdo, $memberCode, $zoneId)) {
            $pdo->prepare("INSERT INTO sylius_zone_member (code, belongs_to) VALUES (?, ?)")
                ->execute([$memberCode, $zoneId]);
        }
    }
}

// ──── TAXONS — Arbre nested set (idempotent par code) ─────────────────────────
//
//  MENU_CATEGORY  [1..22, lvl=0]
//  ├── Barbecues  [2..11, lvl=1]
//  │   ├── mini        [3..4]
//  │   ├── small       [5..6]
//  │   ├── average-bbq [7..8]
//  │   └── big-bbq     [9..10]
//  └── accessories [12..21, lvl=1]
//      ├── tong        [13..14]
//      ├── chairs      [15..16]
//      ├── lighters    [17..18]
//      └── coolers     [19..20]

echo "  → Taxons (arbre catégories)...\n";
$taxonSql = "INSERT INTO sylius_taxon
    (tree_root, parent_id, code, tree_left, tree_right, tree_level, position, enabled, created_at, updated_at)
    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)";

// Racine
$rootCreated = false;
$rootId = find_or_create(
    $pdo, 'sylius_taxon', 'code', 'MENU_CATEGORY',
    $taxonSql, [null, null, 'MENU_CATEGORY', 1, 22, 0, 0, 1, $now, $now],
    $rootCreated
);
if ($rootCreated) {
    // tree_root = id propre
    $pdo->prepare("UPDATE sylius_taxon SET tree_root = ? WHERE id = ?")->execute([$rootId, $rootId]);
    $stats['taxons']['inserted']++;
} else {
    $stats['taxons']['skipped']++;
}

// Barbecues et ses enfants
$taxonsData = [
    ['Barbecues',   $rootId,  2, 11, 1, 4],
    ['mini',        null,     3,  4, 2, 0],
    ['small',       null,     5,  6, 2, 1],
    ['average-bbq', null,     7,  8, 2, 2],
    ['big-bbq',     null,     9, 10, 2, 3],
    ['accessories', $rootId, 12, 21, 1, 5],
    ['tong',        null,    13, 14, 2, 0],
    ['chairs',      null,    15, 16, 2, 1],
    ['lighters',    null,    17, 18, 2, 2],
    ['coolers',     null,    19, 20, 2, 3],
];

// Résolution des parent_id (null = déterminé après) et création
$bbqId = null; $accId = null;
foreach ($taxonsData as &$tData) {
    [$tCode, $tParent, $tLeft, $tRight, $tLevel, $tPos] = $tData;
    // Résolution dynamique du parent_id
    if ($tParent === null) {
        if ($tLevel === 2 && $tLeft < 12) {
            $tParent = $bbqId;   // enfant de Barbecues
        } else {
            $tParent = $accId;   // enfant de Accessories
        }
    }
    $created = false;
    $id = find_or_create(
        $pdo, 'sylius_taxon', 'code', $tCode,
        $taxonSql, [$rootId, $tParent, $tCode, $tLeft, $tRight, $tLevel, $tPos, 1, $now, $now],
        $created
    );
    $created ? $stats['taxons']['inserted']++ : $stats['taxons']['skipped']++;
    $tData[] = $id;  // stocke l'id résolu en position [6]
    if ($tCode === 'Barbecues')   { $bbqId = $id; }
    if ($tCode === 'accessories') { $accId = $id; }
}
unset($tData);

// Reconstruction de la map code → id pour les traductions
$taxonIds = [];
foreach ($taxonsData as $tData) {
    $taxonIds[$tData[0]] = $tData[6];
}
$taxonIds['MENU_CATEGORY'] = $rootId;

// ──── TAXON TRANSLATIONS ──────────────────────────────────────────────────────
echo "  → Traductions des taxons (fr_FR + en_US)...\n";
$translationsMap = [
    'MENU_CATEGORY' => ['fr_FR' => ['Catégorie',     'categorie'],    'en_US' => ['Category',       'category']],
    'Barbecues'     => ['fr_FR' => ['Barbecues',     'bbq'],          'en_US' => ['Barbecues',       'bbq-us']],
    'mini'          => ['fr_FR' => ['Mini barbecue', 'mini-bbq'],     'en_US' => ['Mini barbecue',   'mini-bbq']],
    'small'         => ['fr_FR' => ['Petit barbecue','small-bbq'],    'en_US' => ['Small barbecues', 'small-bbq']],
    'average-bbq'   => ['fr_FR' => ['Moyen bbq',     'average-bbq'],  'en_US' => ['Average bbq',     'average-bbq']],
    'big-bbq'       => ['fr_FR' => ['Grand bbq',     'big-bbq'],      'en_US' => ['Big bbq',         'big-bbq']],
    'accessories'   => ['fr_FR' => ['Accessoires',   'accessories'],  'en_US' => ['Accessories',     'accessories']],
    'tong'          => ['fr_FR' => ['Pinces',         'tong'],        'en_US' => ['Tongs',            'tongs']],
    'chairs'        => ['fr_FR' => ['Chaises',        'chairs'],      'en_US' => ['Chairs',           'chairs']],
    'lighters'      => ['fr_FR' => ['Briquets',       'lighters'],    'en_US' => ['Lighters',         'lighters']],
    'coolers'       => ['fr_FR' => ['Glacière',       'coolers'],     'en_US' => ['Coolers',          'coolers']],
];
$descriptionsMap = [
    'Barbecues' => ['fr_FR' => 'Barbecues', 'en_US' => 'Barbecues'],
];

foreach ($translationsMap as $tCode => $localeMap) {
    $taxonId = $taxonIds[$tCode];
    foreach ($localeMap as $locale => [$name, $slug]) {
        if (!taxon_translation_exists($pdo, $taxonId, $locale)) {
            $desc = $descriptionsMap[$tCode][$locale] ?? null;
            $pdo->prepare(
                "INSERT INTO sylius_taxon_translation (translatable_id, locale, name, slug, description)
                 VALUES (?, ?, ?, ?, ?)"
            )->execute([$taxonId, $locale, $name, $slug, $desc]);
        }
    }
}

// ──── CHANNEL CG_EURO_STORE ────────────────────────────────────────────────────
echo "  → Channel CG_EURO_STORE...\n";
$frLocaleId    = fetch_id($pdo, 'sylius_locale',   'code', 'fr_FR');
$enLocaleId    = fetch_id($pdo, 'sylius_locale',   'code', 'en_US');
$eurCurrencyId = fetch_id($pdo, 'sylius_currency', 'code', 'EUR');
$eeaZoneId     = fetch_id($pdo, 'sylius_zone',     'code', 'EEA');
$frCountryId   = fetch_id($pdo, 'sylius_country',  'code', 'FR');

// Vérifie si le channel existe déjà
$stmtCh = $pdo->prepare("SELECT id, shop_billing_data_id, channel_price_history_config_id FROM sylius_channel WHERE code = ? LIMIT 1");
$stmtCh->execute(['CG_EURO_STORE']);
$existingChannel = $stmtCh->fetch();

if ($existingChannel) {
    $channelId = (int) $existingChannel['id'];
    $stats['channel']['skipped']++;
} else {
    // Billing data
    $pdo->prepare(
        "INSERT INTO sylius_shop_billing_data (company, tax_id, country_code, street, city, postcode) VALUES (?, ?, ?, ?, ?, ?)"
    )->execute(['copolink', '123456789', 'FR', '14 rue basset', 'paris', '75015']);
    $billingDataId = (int) $pdo->lastInsertId();

    // Price history config
    $pdo->prepare(
        "INSERT INTO sylius_channel_price_history_config (lowest_price_for_discounted_products_checking_period, lowest_price_for_discounted_products_visible) VALUES (30, 1)"
    )->execute([]);
    $priceHistoryConfigId = (int) $pdo->lastInsertId();

    $pdo->prepare(
        "INSERT INTO sylius_channel (
            shop_billing_data_id, channel_price_history_config_id,
            default_locale_id, base_currency_id, default_tax_zone_id, menu_taxon_id,
            code, name, color, description, enabled, hostname, theme_name,
            tax_calculation_strategy, contact_email, contact_phone_number,
            skipping_shipping_step_allowed, skipping_payment_step_allowed,
            account_verification_required, shipping_address_in_checkout_required,
            created_at, updated_at
        ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)"
    )->execute([
        $billingDataId, $priceHistoryConfigId,
        $frLocaleId, $eurCurrencyId, $eeaZoneId, $rootId,
        'CG_EURO_STORE', 'Cagrille euro store',
        '#f08c00', 'cagrille store', 1, 'localhost',
        'cagrille/cagrille-theme', 'order_items_based',
        'contact.cagrille@gmail.com', null,
        0, 0, 1, 0,
        $now, $now,
    ]);
    $channelId = (int) $pdo->lastInsertId();
    $stats['channel']['inserted']++;
}

// Relations pivot (INSERT IGNORE = idempotent sur clé composite)
insert_pivot($pdo, 'sylius_channel_locales',    'channel_id', $channelId, 'locale_id',   $frLocaleId);
insert_pivot($pdo, 'sylius_channel_locales',    'channel_id', $channelId, 'locale_id',   $enLocaleId);
insert_pivot($pdo, 'sylius_channel_currencies', 'channel_id', $channelId, 'currency_id', $eurCurrencyId);
insert_pivot($pdo, 'sylius_channel_countries',  'channel_id', $channelId, 'country_id',  $frCountryId);

$pdo->exec('SET FOREIGN_KEY_CHECKS = 1');

// ── Résumé ────────────────────────────────────────────────────────────────────
echo "\n  ✔ Données de référence traitées.\n";
echo "    ┌────────────────┬──────────┬─────────┐\n";
echo "    │ Type           │ Insérés  │ Ignorés │\n";
echo "    ├────────────────┼──────────┼─────────┤\n";
foreach ($stats as $type => $s) {
    printf("    │ %-14s │ %8d │ %7d │\n", $type, $s['inserted'], $s['skipped']);
}
echo "    └────────────────┴──────────┴─────────┘\n";

PHPEOF

success "Données de référence traitées (voir tableau ci-dessus)."

# ──────────────────────────────────────────────────────────────────────────────
# Étape 4 : Création du compte administrateur (via SQL + bcrypt PHP)
# ──────────────────────────────────────────────────────────────────────────────
step "Création du compte administrateur Sylius"
echo ""
echo "  Entrez les informations du compte admin :"
echo -n "  E-mail          [admin@cagrille.fr] : "
read -r ADMIN_EMAIL
ADMIN_EMAIL="${ADMIN_EMAIL:-admin@cagrille.fr}"

echo -n "  Nom d'utilisateur          [admin] : "
read -r ADMIN_USERNAME
ADMIN_USERNAME="${ADMIN_USERNAME:-admin}"

echo -n "  Prénom                   [Admin]   : "
read -r ADMIN_FIRST
ADMIN_FIRST="${ADMIN_FIRST:-Admin}"

echo -n "  Nom de famille        [Cagrille]   : "
read -r ADMIN_LAST
ADMIN_LAST="${ADMIN_LAST:-Cagrille}"

echo -n "  Mot de passe (caché)               : "
read -rs ADMIN_PASSWORD
echo ""
[[ -n "$ADMIN_PASSWORD" ]] || error "Le mot de passe ne peut pas être vide."

# Insertion directe via PHP/PDO : génération du hash bcrypt + INSERT SQL
$PHP << PHPEOF
<?php
function loadDotEnv(string \$file): void
{
    if (!is_file(\$file)) return;
    foreach (file(\$file, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES) as \$line) {
        if (str_starts_with(trim(\$line), '#') || !str_contains(\$line, '=')) continue;
        [\$key, \$value] = explode('=', \$line, 2);
        \$key = trim(\$key); \$value = trim(\$value, " \t\n\r\0\x0B\"'");
        if (!isset(\$_ENV[\$key])) { \$_ENV[\$key] = \$value; putenv("\$key=\$value"); }
    }
}
loadDotEnv('.env'); loadDotEnv('.env.local');

\$rawUrl  = \$_ENV['DATABASE_URL'] ?? getenv('DATABASE_URL') ?? '';
\$appEnv  = \$_ENV['APP_ENV'] ?? getenv('APP_ENV') ?: 'prod';
\$rawUrl  = str_replace('%kernel.environment%', \$appEnv, \$rawUrl);
\$parsed  = parse_url(\$rawUrl);
\$dbName  = strtok(ltrim(\$parsed['path'] ?? '/', '/'), '?');
\$dbHost  = \$parsed['host'];
\$dbPort  = \$parsed['port'] ?? 3306;
\$dbUser  = isset(\$parsed['user']) ? urldecode(\$parsed['user']) : 'root';
\$dbPass  = isset(\$parsed['pass']) ? urldecode(\$parsed['pass']) : '';
\$pdo = new PDO(
    "mysql:host=\$dbHost;port=\$dbPort;dbname=\$dbName;charset=utf8mb4",
    \$dbUser,
    \$dbPass,
    [PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION]
);

\$email    = '${ADMIN_EMAIL}';
\$username = '${ADMIN_USERNAME}';
\$first    = '${ADMIN_FIRST}';
\$last     = '${ADMIN_LAST}';
\$password = '${ADMIN_PASSWORD}';

// Sylius 2.x / Symfony 6+ utilise bcrypt (coût 13 par défaut)
\$hash = password_hash(\$password, PASSWORD_BCRYPT, ['cost' => 13]);
\$now  = date('Y-m-d H:i:s');

\$stmt = \$pdo->prepare("SELECT id FROM sylius_admin_user WHERE email_canonical = ? LIMIT 1");
\$stmt->execute([strtolower(\$email)]);
if (\$stmt->fetch()) {
    echo "  ⚠ Administrateur déjà existant : \$email — ignoré.\n";
} else {
    \$ins = \$pdo->prepare("
        INSERT INTO sylius_admin_user
            (username, username_canonical, email, email_canonical,
             password, enabled, first_name, last_name,
             roles, locale_code, created_at, updated_at)
        VALUES (?, ?, ?, ?, ?, 1, ?, ?, ?, 'fr_FR', ?, ?)
    ");
    \$ins->execute([
        \$username, strtolower(\$username),
        \$email,    strtolower(\$email),
        \$hash,
        \$first, \$last,
        json_encode(['ROLE_ADMINISTRATION_ACCESS']),
        \$now, \$now,
    ]);
    echo "  ✔ Administrateur créé : \$email (username: \$username)\n";
}
PHPEOF

success "Administrateur : $ADMIN_EMAIL / $ADMIN_USERNAME"

# ──────────────────────────────────────────────────────────────────────────────
# Étape 5 : Assets & cache warmup (facultatif en prod)
# ──────────────────────────────────────────────────────────────────────────────
step "Warmup du cache Symfony"
$CONSOLE cache:warmup
success "Cache préchauffé."

# ──────────────────────────────────────────────────────────────────────────────
# Résumé final
# ──────────────────────────────────────────────────────────────────────────────
echo ""
echo -e "${BOLD}${GREEN}═══════════════════════════════════════════════════════════${NC}"
echo -e "${BOLD}${GREEN}  ✔  Initialisation terminée avec succès !${NC}"
echo -e "${BOLD}${GREEN}═══════════════════════════════════════════════════════════${NC}"
echo ""
echo -e "  Admin URL   : https://<votre-domaine>/admin"
echo -e "  Identifiant : ${YELLOW}$ADMIN_EMAIL${NC}"
echo ""
echo -e "  ${BLUE}Données conservées :${NC}"
echo -e "    • Taxons    : MENU_CATEGORY › Barbecues (4 enfants) + Accessoires (4 enfants)"
echo -e "    • Channel   : CG_EURO_STORE (fr_FR / EUR / zone EEA / pays FR)"
echo -e "    • Countries : AT AU BE CA CH CN DE DK ES FR GB IT MX NL NO NZ PL PT SE US"
echo -e "    • Zones     : US · WORLD · EEA"
echo -e "    • Currencies: EUR USD PLN CAD CNY NZD GBP AUD MXN"
echo -e "    • Locales   : en_US de_DE fr_FR pl_PL es_ES es_MX pt_PT zh_CN"
echo ""
