{# Override de @SyliusShop/cart/…/summary.html.twig
   Remplace bg-light (blanc Bootstrap) par le fond sombre du thème Cagrille. #}

{# Rendered with \Sylius\Bundle\ShopBundle\Twig\Component\Cart\SummaryComponent #}
{% import '@SyliusShop/shared/macro/loader.html.twig' as loader %}

<div class="position-relative" {{ attributes }}>
    {{ loader.render() }}
    <div class="p-4 mb-4 rounded-3 bg-coal-700 border border-coal-600 text-ash-100">
        <h3 class="mb-4 text-ash-100">{{ 'sylius.ui.summary'|trans }}</h3>
        {% hook 'summary' with {cart} %}
    </div>
</div>
