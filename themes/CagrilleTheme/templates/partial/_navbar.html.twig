<nav class="sticky top-0 z-50 bg-coal-900/95 backdrop-blur border-b border-coal-700"
     x-data="{ open: false, cartOpen: false }">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">

            {# ── Logo ──────────────────────────────────────── #}
            <a href="{{ path('sylius_shop_homepage') }}"
               class="flex items-center gap-2 group">
                <span class="text-3xl animate-flicker" aria-hidden="true">🔥</span>
                <span class="font-display text-2xl tracking-widest text-fire-gradient">
                    CAGRILLE
                </span>
            </a>

            {# ── Menu principal (desktop) ───────────────────── #}
            <div class="hidden md:flex items-center gap-8">
                <a href="{{ path('sylius_shop_homepage') }}" class="nav-link">Accueil</a>
                <a href="{{ path('sylius_shop_product_index', {'slug': 'barbecues'}) }}" class="nav-link">Produits</a>
                <a href="{{ path('sylius_shop_product_index', {'slug': 'barbecues'}) }}" class="nav-link">Barbecues</a>
                <a href="{{ path('sylius_shop_product_index', {'slug': 'accessoires'}) }}" class="nav-link">Accessoires</a>
                <a href="{{ path('sylius_shop_product_index', {'slug': 'charbons'}) }}" class="nav-link">Charbons</a>
            </div>

            {# ── Actions (recherche, compte, panier) ───────── #}
            <div class="flex items-center gap-4">

                {# Recherche #}
                <form action="{{ path('sylius_shop_product_index', {'slug': 'barbecues'}) }}" method="get"
                      class="hidden md:flex items-center bg-coal-700 rounded-lg border border-coal-600
                             focus-within:border-ember-500 transition-colors">
                    <input type="search" name="criteria[search][value]"
                           placeholder="Rechercher…"
                           class="bg-transparent px-3 py-1.5 text-sm text-ash-100 placeholder-ash-400
                                  focus:outline-none w-48">
                    <button type="submit" class="px-3 py-1.5 text-ash-400 hover:text-ember-400">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                        </svg>
                    </button>
                </form>

                {# Compte #}
                {% if app.user %}
                    <a href="{{ path('sylius_shop_account_dashboard') }}"
                       class="text-ash-300 hover:text-ember-400 transition-colors"
                       title="Mon compte">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                        </svg>
                    </a>
                {% else %}
                    <a href="{{ path('sylius_shop_login') }}"
                       class="text-ash-300 hover:text-ember-400 transition-colors"
                       title="Connexion">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/>
                        </svg>
                    </a>
                {% endif %}

                {# Panier #}
                <a href="{{ path('sylius_shop_cart_summary') }}"
                   class="relative text-ash-300 hover:text-ember-400 transition-colors"
                   title="Panier">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2 9m5-9v9m4-9v9m-4-9h4"/>
                    </svg>
                    {% set cartCount = cagrille_cart_count() %}
                    {% if cartCount > 0 %}
                        <span class="cart-badge">{{ cartCount }}</span>
                    {% endif %}
                </a>

                {# Burger mobile #}
                <button @click="open = !open"
                        class="md:hidden text-ash-300 hover:text-ember-400 transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path x-show="!open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M4 6h16M4 12h16M4 18h16"/>
                        <path x-show="open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>
        </div>
    </div>

    {# Menu mobile #}
    <div x-show="open"
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0 -translate-y-2"
         x-transition:enter-end="opacity-100 translate-y-0"
         class="md:hidden bg-coal-900 border-t border-coal-700 px-4 py-4 space-y-3">
        <a href="{{ path('sylius_shop_homepage') }}" class="block nav-link py-2">Accueil</a>
        <a href="{{ path('sylius_shop_product_index', {'slug': 'barbecues'}) }}" class="block nav-link py-2">Produits</a>
        <a href="{{ path('sylius_shop_product_index', {'slug': 'barbecues'}) }}" class="block nav-link py-2">Barbecues</a>
        <a href="{{ path('sylius_shop_product_index', {'slug': 'accessoires'}) }}" class="block nav-link py-2">Accessoires</a>
        <a href="{{ path('sylius_shop_product_index', {'slug': 'charbons'}) }}" class="block nav-link py-2">Charbons</a>
    </div>
</nav>
