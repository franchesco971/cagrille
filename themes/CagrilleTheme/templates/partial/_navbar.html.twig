<nav class="sticky top-0 z-50 bg-coal-900/95 backdrop-blur border-b border-coal-700"
     x-data="{ open: false, cartOpen: false }">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">

            {# ── Logo ──────────────────────────────────────── #}
            <a href="{{ path('sylius_shop_homepage') }}"
               class="flex items-center gap-2 group">
                <span class="text-3xl animate-flicker" aria-hidden="true">🔥</span>
                <span class="font-display text-2xl tracking-widest text-fire-gradient">
                    CAGRILLE
                </span>
            </a>

            {# ── Menu principal (desktop) ───────────────────── #}
            <div class="hidden md:flex items-center gap-8" {{ sylius_test_html_attribute('menu') }}>
                {% for taxon in cagrille_menu_taxons() %}
                    <a href="{{ path('sylius_shop_product_index', {'slug': taxon.slug, '_locale': taxon.translation.locale}) }}"
                       class="nav-link"
                       {{ sylius_test_html_attribute('menu-item', taxon.name) }}>
                        {{ taxon.name }}
                    </a>
                {% endfor %}
            </div>

            {# ── Actions (recherche, devise, compte, panier) ──── #}
            <div class="flex items-center gap-4">

                {# Sélecteur de locale #}
                {% set available_locales = sylius.channel.locales | map(l => l.code) %}
                {% set active_locale = sylius.localeCode %}
                {% include '@SyliusShop/shared/layout/base/header/top_bar/locale_switcher.html.twig' %}

                {# Sélecteur de devise #}
                {% set available_currencies = sylius.channel.currencies | map(c => c.code) %}
                {% set active_currency = sylius.currencyCode %}
                {% include '@SyliusShop/shared/layout/base/header/top_bar/currency_switcher.html.twig' %}

                {# Recherche #}
                <form action="{{ path('sylius_shop_product_index', {'slug': 'barbecues'}) }}" method="get"
                      class="hidden md:flex items-center bg-coal-700 rounded-lg border border-coal-600
                             focus-within:border-ember-500 transition-colors">
                    <input type="search" name="criteria[search][value]"
                           placeholder="Rechercher…"
                           class="bg-transparent px-3 py-1.5 text-sm text-ash-100 placeholder-ash-400
                                  focus:outline-none w-48">
                    <button type="submit" class="px-3 py-1.5 text-ash-400 hover:text-ember-400">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                        </svg>
                    </button>
                </form>

                {# Compte #}
                {% if app.user %}
                    <span {{ sylius_test_html_attribute('full-name') }} class="text-ash-300 text-sm">
                        {{ 'sylius.ui.hello'|trans }} {{ app.user.customer.firstName }}!
                    </span>
                    <a href="{{ path('sylius_shop_account_dashboard') }}"
                       class="text-ash-300 hover:text-ember-400 transition-colors"
                       title="Mon compte">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                        </svg>
                    </a>
                    <a href="{{ path('sylius_shop_logout') }}"
                       class="text-ash-300 hover:text-ember-400 transition-colors text-sm"
                       title="Déconnexion"
                       {{ sylius_test_html_attribute('button', 'logout-button') }}>
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                        </svg>
                    </a>
                {% else %}
                    <a href="{{ path('sylius_shop_login') }}"
                       class="text-ash-300 hover:text-ember-400 transition-colors"
                       title="Connexion">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/>
                        </svg>
                    </a>
                {% endif %}

                {# Panier #}
                {% set cartCount = cagrille_cart_count() %}
                <a href="{{ path('sylius_shop_cart_summary') }}"
                   class="flex items-center gap-1.5 text-ash-300 hover:text-ember-400 transition-colors"
                   title="Panier"
                   {{ sylius_test_html_attribute('cart-button') }}>
                    <svg class="w-6 h-6 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2 9m5-9v9m4-9v9m-4-9h4"/>
                    </svg>
                    <span {{ sylius_test_html_attribute('cart-total') }} class="sr-only">
                        {{- cagrille_cart_total() | sylius_format_money(sylius.currencyCode, sylius.localeCode) -}}
                    </span>
                    <!-- <span class="text-sm font-medium">{{ cartCount > 0 ? cartCount : '0' }}</span> -->
                </a>

                {# Burger mobile #}
                <button @click="open = !open"
                        class="md:hidden text-ash-300 hover:text-ember-400 transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path x-show="!open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M4 6h16M4 12h16M4 18h16"/>
                        <path x-show="open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>
        </div>
    </div>

    {# Menu mobile – pattern Tailwind UI (display:none SSR, x-show Alpine) #}
    <div style="display: none"
         x-show="open"
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0 -translate-y-1"
         x-transition:enter-end="opacity-100 translate-y-0"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="opacity-100 translate-y-0"
         x-transition:leave-end="opacity-0 -translate-y-1"
         class="md:hidden bg-coal-900 border-t border-coal-700">
        <div class="space-y-1 px-2 pb-3 pt-2">

            {% for taxon in cagrille_menu_taxons() %}
                <a href="{{ path('sylius_shop_product_index', {'slug': taxon.slug, '_locale': taxon.translation.locale}) }}"
                   class="block rounded-md px-3 py-2 text-base font-medium text-ash-200
                          hover:bg-coal-700 hover:text-ember-400 transition-colors"
                   {{ sylius_test_html_attribute('menu-item', taxon.name) }}>
                    {{ taxon.name }}
                </a>
            {% endfor %}

            <div class="border-t border-coal-700 my-1 mx-3"></div>

            {% if app.user %}
                <a href="{{ path('sylius_shop_account_dashboard') }}"
                   class="block rounded-md px-3 py-2 text-base font-medium text-ash-200
                          hover:bg-coal-700 hover:text-ember-400 transition-colors">
                    Mon compte
                </a>
                <a href="{{ path('sylius_shop_logout') }}"
                   class="block rounded-md px-3 py-2 text-base font-medium text-ash-200
                          hover:bg-coal-700 hover:text-ember-400 transition-colors"
                   {{ sylius_test_html_attribute('button', 'logout-button') }}>
                    {{ 'sylius.ui.logout'|trans }}
                </a>
            {% else %}
                <a href="{{ path('sylius_shop_login') }}"
                   class="block rounded-md px-3 py-2 text-base font-medium text-ash-200
                          hover:bg-coal-700 hover:text-ember-400 transition-colors">
                    Connexion
                </a>
            {% endif %}
        </div>
    </div>
</nav>
