{% if products is defined and products|length > 0 %}
<section class="py-16 bg-coal-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="flex items-end justify-between mb-10">
            <div>
                <h2 class="font-display text-4xl text-fire-gradient">MEILLEURES VENTES</h2>
                <div class="fire-divider max-w-xs mt-3"></div>
                <p class="text-ash-400 mt-2">Les incontournables de notre sélection BBQ</p>
            </div>
            {% if rootTaxonSlug is not null %}
            <a href="{{ path('sylius_shop_product_index', {'slug': rootTaxonSlug}) }}"
               class="btn-coal text-sm hidden sm:inline-flex">
                Voir tout →
            </a>
            {% endif %}
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            {% for product in products %}
                <div class="group">
                    {% include '@CagrilleTheme/product/_card.html.twig' with { product: product } %}
                </div>
            {% endfor %}
        </div>

        {% if rootTaxonSlug is not null %}
        <div class="mt-8 text-center sm:hidden">
            <a href="{{ path('sylius_shop_product_index', {'slug': rootTaxonSlug}) }}" class="btn-coal">
                Voir tous les produits →
            </a>
        </div>
        {% endif %}

    </div>
</section>
{% endif %}
